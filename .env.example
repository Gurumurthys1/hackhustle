# TriNetra AI — Environment Variables
# Copy this file to .env and fill in your values.
# The start_services.ps1 script sets these automatically for local dev.

# ── DATABASE ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://trinetra:trinetra_dev@localhost:5433/trinetra

# ── MESSAGE QUEUE (Redpanda — Kafka compatible) ────────────────────────────
KAFKA_BROKERS=localhost:9092

# ── CACHE ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── OBJECT STORAGE (MinIO — open-source S3 compatible) ───────────────────────
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=trinetra
MINIO_SECRET_KEY=trinetra_dev_secret
MINIO_BUCKET=trinetra-claims

# ── ML MODELS ─────────────────────────────────────────────────────────────────
# CLIP model is downloaded from HuggingFace on first run (~340MB)
# Set this path to a local cache dir to avoid re-downloading
CLIP_MODEL_CACHE=/tmp/clip_cache
# Path to Tesseract OCR binary
TESSERACT_CMD=tesseract

# ── CARRIER APIS (Sandbox / Free tiers) ──────────────────────────────────────
DELHIVERY_API_KEY=your_delhivery_sandbox_key_here
SHIPROCKET_API_KEY=your_shiprocket_sandbox_key_here

# ── COMPLIANCE FLAGS (ALL MANDATORY — startup will FAIL if missing) ──────────
DATA_RETENTION_DAYS=730              # 24 months max (DPDPA 2023 requirement)
CONSENT_REQUIRED=true                # Block all processing without user consent
AUDIT_LOG_IMMUTABLE=true             # Audit log cannot be modified
SOCIAL_MEDIA_SCRAPING_ENABLED=false  # MUST remain false — illegal under DPDPA
BIOMETRIC_PROCESSING_ENABLED=false   # MUST remain false without KYC consent
AUTO_BLOCK_ENABLED=false             # MUST remain false — Consumer Protection Act 2019
CUSTOMER_SCORE_EXPOSED=false         # MUST remain false — score is internal only

# ── AUTHENTICATION ────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=CHANGE_ME_generate_256_bit_secret_here
JWT_EXPIRY_HOURS=8

# ── MONITORING ────────────────────────────────────────────────────────────────
PROMETHEUS_PORT=8002
GRAFANA_ADMIN_PASSWORD=admin          # Change in production

# ── SERVICE PORTS (for reference) ─────────────────────────────────────────────
# Return API (Spring Boot):  8085
# Fraud Engine (FastAPI):    8000
# Graph Service (FastAPI):   8001
# Prometheus metrics:        8002
# Admin Dashboard (Vite):    5173
# Customer Portal (Vite):    5174
# Grafana:                   3001
# MinIO Console:             9001
# Redpanda Console:          8081
# Traefik Dashboard:         8090
# PgAdmin:                   5050
